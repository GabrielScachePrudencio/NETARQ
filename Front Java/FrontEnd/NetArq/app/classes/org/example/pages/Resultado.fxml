<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ResultadoController"
            stylesheets="@../styles/theme.css">

    <center>
        <SplitPane dividerPositions="0.5">

            <!-- ===================== PAINEL ESQUERDO: MEU COMPUTADOR ===================== -->
            <VBox>
                <HBox styleClass="painel-titulo" alignment="CENTER_LEFT" spacing="8">
                    <Label text="💻" />
                    <Label fx:id="lblNomeLocal" text="Meu computador" styleClass="painel-nome" />
                </HBox>

                <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="8">
                    <Button fx:id="btnVoltarHistLocal" text="←" styleClass="nav-icon-btn" onAction="#voltarHistoricoLocal" />
                    <Button fx:id="btnSubirLocal" text="↑" styleClass="nav-icon-btn" onAction="#subirPastaLocal" />
                    <Button fx:id="btnHomeLocal" text="⌂" styleClass="nav-icon-btn" onAction="#irParaHomeLocal" />
                    <Button fx:id="btnAtualizarLocal" text="⟳" styleClass="nav-icon-btn" onAction="#atualizarLocal" />
                    <TextField fx:id="txtCaminhoLocal" styleClass="caminho-field" onAction="#navegarPorTextoLocal"
                               HBox.hgrow="ALWAYS" />
                </HBox>

                <TableView fx:id="tabelaLocal" styleClass="tabela-arquivos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNomeLocal" text="Nome" prefWidth="220" />
                        <TableColumn fx:id="colTipoLocal" text="Tipo" prefWidth="90" />
                        <TableColumn fx:id="colTamanhoLocal" text="Tamanho" prefWidth="80" />
                        <TableColumn fx:id="colDataLocal" text="Modificado" prefWidth="130" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox styleClass="status-bar" alignment="CENTER_LEFT">
                    <Label fx:id="lblStatusLocal" text="0 itens" styleClass="status-texto" />
                </HBox>
            </VBox>

            <!-- ===================== PAINEL DIREITO: COMPUTADOR CONECTADO ===================== -->
            <VBox>
                <HBox styleClass="painel-titulo" alignment="CENTER_LEFT" spacing="8">
                    <Label text="🖥️" />
                    <Label fx:id="lblNomeRemoto" text="Computador conectado" styleClass="painel-nome" />
                </HBox>

                <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="8">
                    <Button fx:id="btnVoltarHistRemoto" text="←" styleClass="nav-icon-btn" onAction="#voltarHistoricoRemoto" />
                    <Button fx:id="btnSubirRemoto" text="↑" styleClass="nav-icon-btn" onAction="#subirPastaRemoto" />
                    <Button fx:id="btnHomeRemoto" text="⌂" styleClass="nav-icon-btn" onAction="#irParaHomeRemoto" />
                    <Button fx:id="btnAtualizarRemoto" text="⟳" styleClass="nav-icon-btn" onAction="#atualizarRemoto" />
                    <TextField fx:id="txtCaminhoRemoto" styleClass="caminho-field" onAction="#navegarPorTextoRemoto"
                               HBox.hgrow="ALWAYS" />
                </HBox>

                <TableView fx:id="tabelaRemoto" styleClass="tabela-arquivos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNomeRemoto" text="Nome" prefWidth="220" />
                        <TableColumn fx:id="colTipoRemoto" text="Tipo" prefWidth="90" />
                        <TableColumn fx:id="colTamanhoRemoto" text="Tamanho" prefWidth="80" />
                        <TableColumn fx:id="colDataRemoto" text="Modificado" prefWidth="130" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox styleClass="status-bar" alignment="CENTER_LEFT">
                    <Label fx:id="lblStatusRemoto" text="0 itens" styleClass="status-texto" />
                </HBox>
            </VBox>

        </SplitPane>
    </center>

</BorderPane>