<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.TelaPesquisaController"
            stylesheets="@../styles/theme.css">

   <top>
      <HBox styleClass="top-bar" alignment="CENTER_LEFT">
         <Button text="← Voltar" styleClass="button-voltar" onAction="#voltar" />
      </HBox>
   </top>

   <center>
      <VBox alignment="CENTER" spacing="14">
         <padding>
            <Insets top="40" right="60" bottom="40" left="60" />
         </padding>

         <Label text="Pesquisar arquivos" styleClass="titulo" />
         <Label text="Escolha ou digite o caminho que deseja explorar" styleClass="subtitulo" />

         <Region prefHeight="10" />

         <Label text="Caminho" styleClass="label-campo" />

         <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="txtCaminho"
                       promptText="Ex: C:\Users\SeuUsuario\Documents"
                       HBox.hgrow="ALWAYS" />
            <Button text="Procurar..." styleClass="button-secondary" onAction="#abrirExplorador" />
         </HBox>

         <Region prefHeight="10" />

         <Button text="Pesquisar" onAction="#pesquisarPeloCaminho" />
      </VBox>
   </center>

</BorderPane>