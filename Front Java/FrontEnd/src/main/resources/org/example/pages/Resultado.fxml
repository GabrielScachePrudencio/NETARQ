<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="450.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ResultadoController"
            stylesheets="@../styles/theme.css">

    <top>
        <VBox>
            <!-- Barra de navegação -->
            <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="8">
                <Button fx:id="btnVoltarHist" text="←" styleClass="nav-icon-btn" onAction="#voltarHistorico" />
                <Button fx:id="btnSubir" text="↑" styleClass="nav-icon-btn" onAction="#subirPasta" />
                <Button fx:id="btnHome" text="⌂" styleClass="nav-icon-btn" onAction="#irParaHome" />
                <Button fx:id="btnAtualizar" text="⟳" styleClass="nav-icon-btn" onAction="#atualizar" />
                <TextField fx:id="txtCaminho" styleClass="caminho-field" onAction="#navegarPorTexto"
                           HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tabela" styleClass="tabela-arquivos">
            <columns>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="320" />
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120" />
                <TableColumn fx:id="colTamanho" text="Tamanho" prefWidth="100" />
                <TableColumn fx:id="colData" text="Data de modificação" prefWidth="170" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>

    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <Label fx:id="lblStatus" text="0 itens" styleClass="status-texto" />
        </HBox>
    </bottom>

</BorderPane>